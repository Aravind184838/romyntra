# ============================================
# ROMYNTRA BACKEND — ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────────
# MongoDB — Choose one:
# Option A: Local MongoDB (default, no setup needed)
MONGO_URI=mongodb://localhost:27017/romyntra

# Option B: MongoDB Atlas (cloud)
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/romyntra?retryWrites=true&w=majority
# ─────────────────────────────────────────────

# JWT — Generate a random secret: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here-must-be-changed-in-production
JWT_EXPIRE=30d

# OTP (development only)
OTP_EXPIRE_MINUTES=10

# ─────────────────────────────────────────────
# Cloudinary (Optional — for photo uploads)
# Get free account at: https://cloudinary.com
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
# Firebase (Optional — for real OTP & Auth)
# Get from Firebase Console > Project Settings > Service Account
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_PRIVATE_KEY=your_private_key
# FIREBASE_CLIENT_EMAIL=your_client_email
# ─────────────────────────────────────────────

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Admin email (for initial admin setup — password must be set via env var)
ADMIN_EMAIL=admin@romyntra.com

# ============================================
# ROMYNTRA BACKEND — ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────────
# MongoDB — Choose one:
# Option A: Local MongoDB (default, no setup needed)
MONGO_URI=mongodb://localhost:27017/romyntra

# Option B: MongoDB Atlas (cloud)
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/romyntra?retryWrites=true&w=majority
# ─────────────────────────────────────────────

# JWT — Change this to a long random string in production!
JWT_SECRET=romyntra_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRE=30d

# OTP (Mock — for development. Replace with Firebase in production)
OTP_EXPIRE_MINUTES=10
DEV_OTP=123456

# ─────────────────────────────────────────────
# Cloudinary (Optional — for photo uploads)
# Get free account at: https://cloudinary.com
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
# Firebase (Optional — for real OTP & Auth)
# Get from Firebase Console > Project Settings > Service Account
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_PRIVATE_KEY=your_private_key
# FIREBASE_CLIENT_EMAIL=your_client_email
# ─────────────────────────────────────────────

# Encryption key for chat messages (32 chars exactly)
ENCRYPTION_KEY=romyntra_encrypt_key_32chars_abc!

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Admin credentials (for initial admin setup)
ADMIN_EMAIL=admin@romyntra.com
ADMIN_PASSWORD=Admin@123
